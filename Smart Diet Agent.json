      "parameters": {
        "jsCode": "// 1. 取得上一個節點傳進來的資料\nconst inputData = $input.first().json;\n\n// 2. 提取準備要發送的回覆內容\nconst replyText = inputData.reply_text || \"\";\n\n// 3. 語言偵測 (檢查回覆內容中是否包含中文字)\nconst hasHanzi = /[\\u4e00-\\u9fa5]/.test(replyText);\n\nlet language = \"English\";\nif (hasHanzi) {\n    language = \"Chinese\";\n}\n\n// 4. 輸出結果給下一個節點 (HTTP Request)\nreturn [{\n    json: {\n        error: false,\n        language: language,\n        remoteJid: $('Webhook').first().json.body.data.key.remoteJid,\n        sender:$('Webhook').first().json.body.sender,\n        reply: $input.first().json.output.agent_reply,\n        mode:$input.first().json.output.mode,\n        details:$input.first().json.output.details\n    }\n}];"
      },
